{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/figma designs/index.html" },
    { "source": "/index(.html)?", "destination": "/figma designs/index.html" },
    { "source": "/about(.html)?", "destination": "/figma designs/about.html" },
    { "source": "/contact(.html)?", "destination": "/figma designs/contact.html" },
    { "source": "/login(.html)?", "destination": "/figma designs/login.html" },
    { "source": "/signup(.html)?", "destination": "/figma designs/signup.html" },
    { "source": "/services(.html)?", "destination": "/figma designs/services.html" },
    { "source": "/testimonials(.html)?", "destination": "/figma designs/testimonials.html" },
    { "source": "/product-trade(.html)?", "destination": "/figma designs/product-trade.html" },
    { "source": "/product-loan(.html)?", "destination": "/figma designs/product-loan.html" },
    { "source": "/product-wealth(.html)?", "destination": "/figma designs/product-wealth.html" },
    { "source": "/styles.css", "destination": "/figma designs/styles.css" },
    { "source": "/main.js", "destination": "/figma designs/main.js" },
    { "source": "/images/:path*", "destination": "/figma designs/images/:path*" }
  ]
}
