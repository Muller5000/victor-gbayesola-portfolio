{
  "cleanUrls": true,
  "routes": [
    { "src": "^/$", "dest": "/figma-designs/index.html" },
    { "src": "^/index$", "dest": "/figma-designs/index.html" },
    { "src": "^/index\\.html$", "dest": "/figma-designs/index.html" },
    { "src": "^/about$", "dest": "/figma-designs/about.html" },
    { "src": "^/about\\.html$", "dest": "/figma-designs/about.html" },
    { "src": "^/contact$", "dest": "/figma-designs/contact.html" },
    { "src": "^/contact\\.html$", "dest": "/figma-designs/contact.html" },
    { "src": "^/login$", "dest": "/figma-designs/login.html" },
    { "src": "^/login\\.html$", "dest": "/figma-designs/login.html" },
    { "src": "^/signup$", "dest": "/figma-designs/signup.html" },
    { "src": "^/signup\\.html$", "dest": "/figma-designs/signup.html" },
    { "src": "^/services$", "dest": "/figma-designs/services.html" },
    { "src": "^/services\\.html$", "dest": "/figma-designs/services.html" },
    { "src": "^/testimonials$", "dest": "/figma-designs/testimonials.html" },
    { "src": "^/testimonials\\.html$", "dest": "/figma-designs/testimonials.html" },
    { "src": "^/product-trade$", "dest": "/figma-designs/product-trade.html" },
    { "src": "^/product-trade\\.html$", "dest": "/figma-designs/product-trade.html" },
    { "src": "^/product-loan$", "dest": "/figma-designs/product-loan.html" },
    { "src": "^/product-loan\\.html$", "dest": "/figma-designs/product-loan.html" },
    { "src": "^/product-wealth$", "dest": "/figma-designs/product-wealth.html" },
    { "src": "^/product-wealth\\.html$", "dest": "/figma-designs/product-wealth.html" },
    { "src": "^/styles\\.css$", "dest": "/figma-designs/styles.css" },
    { "src": "^/main\\.js$", "dest": "/figma-designs/main.js" },
    { "src": "^/images/(.*)$", "dest": "/figma-designs/images/$1" },
    { "src": "^/portfolio$", "dest": "/portfolio.html" },
    { "src": "^/portfolio\\.html$", "dest": "/portfolio.html" }
  ]
}
